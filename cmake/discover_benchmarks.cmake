if(NOT DEFINED BENCHMARK_EXECUTABLE)
  message(FATAL_ERROR "BENCHMARK_EXECUTABLE is required")
endif()

if(NOT DEFINED BENCHMARK_TESTS_FILE)
  message(FATAL_ERROR "BENCHMARK_TESTS_FILE is required")
endif()

get_filename_component(script_dir "${CMAKE_CURRENT_LIST_FILE}" DIRECTORY)

execute_process(
  COMMAND "${BENCHMARK_EXECUTABLE}" --benchmark_list_tests --benchmark_filter=^test/
  RESULT_VARIABLE benchmark_result
  OUTPUT_VARIABLE benchmark_output
  ERROR_VARIABLE benchmark_error
)

if(NOT benchmark_result EQUAL 0)
  message(FATAL_ERROR
    "Failed to discover benchmarks from ${BENCHMARK_EXECUTABLE}\n${benchmark_error}"
  )
endif()

string(REPLACE "\\" "\\\\" escaped_executable "${BENCHMARK_EXECUTABLE}")
string(REPLACE "\\" "\\\\" escaped_check_script "${script_dir}/check_benchmark.cmake")
string(REPLACE "\n" ";" benchmark_tests "${benchmark_output}")

set(generated "# Generated by cmake/discover_benchmarks.cmake\n")
string(APPEND generated
  "add_test([=[Benchmark/dry_run]=]\n"
  "  [=[${escaped_executable}]=] --benchmark_dry_run [=[--benchmark_filter=^test/]=]\n"
  ")\n"
  "set_tests_properties([=[Benchmark/dry_run]=] PROPERTIES LABELS [=[benchmark]=])\n"
)
set(candidate_prefixes)
set(grouped_prefixes)
set(emitted_groups)

function(escape_regex out_var input)
  string(REGEX REPLACE "([][+.*()^$?|{}\\\\])" "\\\\\\1" escaped "${input}")
  set("${out_var}" "${escaped}" PARENT_SCOPE)
endfunction()

foreach(benchmark_name IN LISTS benchmark_tests)
  if(benchmark_name STREQUAL "")
    continue()
  endif()

  string(REGEX REPLACE "/real_time$" "" benchmark_base "${benchmark_name}")
  if(benchmark_base MATCHES "^(.*)/[0-9]+$")
    list(APPEND candidate_prefixes "${CMAKE_MATCH_1}")
  endif()
endforeach()

foreach(candidate_prefix IN LISTS candidate_prefixes)
  list(FIND grouped_prefixes "${candidate_prefix}" already_grouped)
  if(NOT already_grouped EQUAL -1)
    continue()
  endif()

  set(candidate_count 0)
  foreach(other_prefix IN LISTS candidate_prefixes)
    if(other_prefix STREQUAL candidate_prefix)
      math(EXPR candidate_count "${candidate_count} + 1")
    endif()
  endforeach()

  if(candidate_count GREATER 1)
    list(APPEND grouped_prefixes "${candidate_prefix}")
  endif()
endforeach()

foreach(benchmark_name IN LISTS benchmark_tests)
  if(benchmark_name STREQUAL "")
    continue()
  endif()

  string(REGEX REPLACE "/real_time$" "" benchmark_base "${benchmark_name}")
  set(test_name "${benchmark_base}")
  escape_regex(benchmark_filter "${benchmark_name}")

  if(benchmark_base MATCHES "^(.*)/[0-9]+$")
    set(candidate_prefix "${CMAKE_MATCH_1}")
    list(FIND grouped_prefixes "${candidate_prefix}" grouped_index)

    if(NOT grouped_index EQUAL -1)
      list(FIND emitted_groups "${candidate_prefix}" emitted_index)
      if(NOT emitted_index EQUAL -1)
        continue()
      endif()

      list(APPEND emitted_groups "${candidate_prefix}")
      set(test_name "${candidate_prefix}")
      escape_regex(benchmark_filter "${candidate_prefix}")
      set(benchmark_filter "${benchmark_filter}/[0-9]+/real_time")
    endif()
  endif()

  string(APPEND generated
    "add_test([=[Benchmark/${test_name}]=]\n"
    "  [=[${CMAKE_COMMAND}]=]\n"
    "    [=[-DBENCHMARK_EXECUTABLE=${escaped_executable}]=]\n"
    "    [=[-DBENCHMARK_FILTER=^${benchmark_filter}$]=]\n"
    "    [=[-DBENCHMARK_NAME=${test_name}]=]\n"
    "    -P [=[${escaped_check_script}]=]\n"
    ")\n"
    "set_tests_properties([=[Benchmark/${test_name}]=] PROPERTIES LABELS [=[benchmark]=])\n"
  )
endforeach()

file(WRITE "${BENCHMARK_TESTS_FILE}" "${generated}")
